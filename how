pipeline {
    agent any
    stages {
        stage('Checkout Local') {
            steps {
                // This tells Jenkins to grab code from your folder instead of GitHub
                checkout([$class: 'GitSCM', 
                    branches: [[name: '*/main']], 
                    userRemoteConfigs: [[url: 'file:///C:/Users/LENOVO/Desktop/my app']]
                ])
            }
        }
        stage('Build') {
            steps {
                // For Windows localhost, use 'bat'
                bat 'mvn clean package'
            }
        }
        stage('Test') {
            steps {
                bat 'mvn test'
            }
        }
    }
}
